            kwargs = {}
            # if LOCAL_TEST:
            #     kwargs['needle'] = 'btop'
            dump_memory(out, **kwargs)
        logger.info(f"wrote {mem_dump.stat().st_size/MiB:.2f} MiB to {mem_dump}")
    finally:
