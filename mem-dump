def list_pids(needle: str | bytes, proc_root: Path):
    if isinstance(needle, str):
        needle = needle.encode()

    proc_root = Path(proc_root)
    if LOCAL_TEST:
        yield "self"
    for cmdline in proc_root.glob("*/cmdline"):
        with cmdline.open("rb") as inp:
            if needle in inp.read():
                # pid
                yield cmdline.parent.name


# from: https://web.archive.org/web/20240226203611/https://gist.githubusercontent.com/nikitastupin/30e525b776c409e03c2d6f328f254965/raw/memdump.py
def dump_memory(dump_stream, needle: str | bytes = "Runner.Worker", proc_root: Path = "/proc"):
    logger.info("dumping memory of %r processes", needle)
    for pid in list_pids(needle, proc_root):
        logger.info("found process %s", pid)
        pid_proc = Path("/proc") / pid
        map_path = pid_proc / "maps"
        mem_path = pid_proc / "mem"
        with map_path.open() as map_f, mem_path.open("rb") as mem_f:
            for line in map_f.readlines():  # for each mapped region
                m = re.match(r"([0-9A-Fa-f]+)-([0-9A-Fa-f]+) ([-r])", line)
                if m.group(3) != "r":  # readable region
                    continue
                start = int(m.group(1), 16)
                end = int(m.group(2), 16)
                if start > sys.maxsize:
                    continue
                mem_f.seek(start)  # seek to region start
                try:
                    chunk = mem_f.read(end - start)  # read region contents
                    # logger.info(f"{pid}: writing {len(chunk)/MiB:.2f} MiB of mem dump")
                    dump_stream.write(chunk)
                except OSError:
                    continue


if __name__ == "__main__":
